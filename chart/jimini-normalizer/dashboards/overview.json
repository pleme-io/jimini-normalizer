        { "expr": "histogram_quantile(0.95, sum(rate(jimini_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 (5m)" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "id": 106,
      "title": "Worker & Outbox Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 51 },
      "id": 60,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
