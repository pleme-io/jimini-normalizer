        { "expr": "histogram_quantile(0.95, sum(rate(jimini_postgres_sink_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(jimini_postgres_sink_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
