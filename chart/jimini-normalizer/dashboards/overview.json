{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Availability (5m)",
      "type": "stat",
      "targets": [
        {
          "expr": "1 - (sum(rate(jimini_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(jimini_http_requests_total[5m])))",
          "legendFormat": ""
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(jimini_http_requests_total[5m]))", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Error Rate (5m)",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(jimini_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(jimini_http_requests_total[5m]))", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "P99 Latency",
      "type": "stat",
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(jimini_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Failed Records Pending",
      "type": "stat",
      "targets": [
        { "expr": "jimini_failed_records_pending", "legendFormat": "" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Schema Violations (1h)",
      "type": "stat",
      "targets": [
        { "expr": "jimini_schema_violations_recent", "legendFormat": "" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "RED Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Request Rate by Path",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (path) (rate(jimini_http_requests_total[5m]))", "legendFormat": "{{ path }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "min": 0, "max": 1 }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Error Rate by Path",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (path) (rate(jimini_http_requests_total{status=~\"5..\"}[5m])) / sum by (path) (rate(jimini_http_requests_total[5m]))", "legendFormat": "{{ path }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(jimini_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(jimini_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(jimini_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Normalization Pipeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Normalizations by Provider",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (provider) (rate(jimini_normalizations_total{status=\"success\"}[5m]))", "legendFormat": "{{ provider }} (ok)" },
        { "expr": "sum by (provider) (rate(jimini_normalizations_total{status=\"error\"}[5m]))", "legendFormat": "{{ provider }} (err)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Assessments Stored Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(jimini_assessments_stored_total[5m])", "legendFormat": "stored/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Normalization Failure Rate by Provider",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (provider) (rate(jimini_normalizations_total{status=\"error\"}[5m])) / sum by (provider) (rate(jimini_normalizations_total[5m]))", "legendFormat": "{{ provider }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "NATS JetStream",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Consumer Pending Messages",
      "type": "timeseries",
      "targets": [
        { "expr": "nats_consumer_num_pending{stream_name=~\"JIMINI_.*\"}", "legendFormat": "{{ stream_name }} / {{ consumer_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Stream Message Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(nats_stream_total_messages{stream_name=~\"JIMINI_.*\"}[5m])", "legendFormat": "{{ stream_name }}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "id": 32,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Consumer Ack / Redelivery Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(nats_consumer_num_ack_pending{stream_name=~\"JIMINI_.*\"}[5m])", "legendFormat": "{{ consumer_name }} ack-pending" },
        { "expr": "rate(nats_consumer_num_redelivered{stream_name=~\"JIMINI_.*\"}[5m])", "legendFormat": "{{ consumer_name }} redelivered" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Audit & Data Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 33 },
      "id": 40,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Failed Records Pending",
      "type": "timeseries",
      "targets": [
        { "expr": "jimini_failed_records_pending", "legendFormat": "pending" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 33 },
      "id": 41,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Schema Violations (Last Hour)",
      "type": "timeseries",
      "targets": [
        { "expr": "jimini_schema_violations_recent", "legendFormat": "violations" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 33 },
      "id": 42,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Outbox Status",
      "type": "timeseries",
      "targets": [
        { "expr": "jimini_outbox_pending", "legendFormat": "pending" },
        { "expr": "jimini_outbox_failed", "legendFormat": "failed" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 105,
      "title": "SLO Burn Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0 }, { "color": "green", "value": 0.5 }] },
          "unit": "percentunit", "min": -1, "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 42 },
      "id": 50,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
