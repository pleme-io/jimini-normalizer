      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 42 },
