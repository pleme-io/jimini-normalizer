      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ops", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 51 },
      "id": 63,
      "options": { "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" } },
      "title": "Poison Messages",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(jimini_worker_messages_total{status=\"poison\"}[5m]))", "legendFormat": "worker" },
        { "expr": "sum(rate(jimini_outbox_processed_total{status=\"poison\"}[5m]))", "legendFormat": "outbox" }
      ]
    },
