        { "expr": "sum(rate(jimini_http_requests_total{status=~\"5..\"}[1h])) / sum(rate(jimini_http_requests_total[1h]))", "legendFormat": "1h" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 42 },
      "id": 52,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Latency SLI Trend",
      "type": "timeseries",
      "targets": [
